@AGIASM 1
@AGI 0.0.1
program compile_stream
module samples/streams/compile_stream
entrypoint
call Main
procedure Main
push stream
def
pop [0]
push [0]
push file
push 1
defgen
pop [1]
push [1]
push string: "stream1"
push 1
callobj "open"
label streamwait_loop_1
push [1]
push string: "delta"
streamwaitobj
pop [2]
pop [3]
pop [4]
cmp [2], 1
je streamwait_loop_1_end
push [3]
push 1
call compile
await
pop [5]
jmp streamwait_loop_1
label streamwait_loop_1_end
