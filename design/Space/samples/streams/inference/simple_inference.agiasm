@AGIASM 1
@AGI 0.0.1
program simple_inference
module streams/inference
entrypoint
push 0
call Main
procedure Main
push vault
push 1
def
pop [0]
push [0]
push string: "token"
push 0
push 2
callobj "get"
pop [1]
push stream
push 1
def
pop [2]
push [2]
push inference
push openai
push 2
defgen
pop [3]
push string: "[]"
pop [4]
push string: "{}"
pop [5]
call opjson, [5], operation: "set", path: "token", [1]
pop [0]
call opjson, [5], operation: "set", path: "history", [4]
pop [0]
push [3]
push [5]
push 1
callobj "open"
pop [0]
push [3]
push string: "{ data: [{ currentTime: :time, weather: [ { location: \"Astana\", time: :time, temperature: \"-15C\" } ] }], system: \"Ты профессиональный чат бот по ИТ, отвечай в деловом тоне.\", instruction: \"Какая щас погода в Астане?\" }"
push 0
push 2
callobj "write"
pop [6]
label streamwait_loop_1
push [6]
push string: "delta"
streamwaitobj
pop [7]
pop [8]
pop [9]
cmp [7], 1
je streamwait_loop_1_end
push 0
call streamwait_loop_1_delta
jmp streamwait_loop_1
label streamwait_loop_1_delta
push [8]
push string: "text"
getobj
pop [10]
push [10]
push 1
call print
pop [0]
push string: "print"
push [10]
push 1
streamwait
ret
label streamwait_loop_1_end
ret
