<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:CompileBindings="False"
        x:Class="Space.OS.Terminal2.SplashWindow"
        SystemDecorations="None"
        CanResize="False"
        Width="980"
        Height="620"
        ShowInTaskbar="False"
        Topmost="True"
        Background="Transparent"
        Opacity="0"
        TransparencyLevelHint="Transparent"
        WindowStartupLocation="CenterScreen">

    <!-- Чуть светлее подложка под скругление (DWM/Skia иначе чем WPF). -->
    <Border CornerRadius="20" Background="#0B1434" BorderBrush="#2B3A75" BorderThickness="1">
        <!-- Как WPF SplashWindow: фон + дети на одном Grid, масштаб от центра -->
        <Grid x:Name="SplashRootGrid" RenderTransformOrigin="50%,50%">
            <Grid.Background>
                <!-- WPF: Center по умолчанию 0.5,0.5; GradientOrigin 0.5,0.45; RadiusX/Y 0.9 -->
                <!-- Те же относительные параметры, что у WPF; стопы чуть светлее — компенсация отличий Skia от WPF. -->
                <RadialGradientBrush Center="50%,50%"
                                     GradientOrigin="50%,45%"
                                     RadiusX="0.9"
                                     RadiusY="0.9">
                    <GradientStop Color="#243A88" Offset="0.0" />
                    <GradientStop Color="#121E52" Offset="0.45" />
                    <GradientStop Color="#0A1436" Offset="1.0" />
                </RadialGradientBrush>
            </Grid.Background>

            <Canvas>
                <Ellipse Width="340" Height="340"
                         Canvas.Left="160" Canvas.Top="80"
                         StrokeThickness="2">
                    <Ellipse.Stroke>
                        <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                            <GradientStop Color="#66B7FF" Offset="0" />
                            <GradientStop Color="#AF7CFF" Offset="1" />
                        </LinearGradientBrush>
                    </Ellipse.Stroke>
                </Ellipse>
                <Ellipse Width="340" Height="340"
                         Canvas.Left="460" Canvas.Top="80"
                         StrokeThickness="2">
                    <Ellipse.Stroke>
                        <LinearGradientBrush StartPoint="100%,0%" EndPoint="0%,100%">
                            <GradientStop Color="#AF7CFF" Offset="0" />
                            <GradientStop Color="#66B7FF" Offset="1" />
                        </LinearGradientBrush>
                    </Ellipse.Stroke>
                </Ellipse>
            </Canvas>

            <TextBlock HorizontalAlignment="Center"
                       Margin="0,350,0,0"
                       VerticalAlignment="Top"
                       FontSize="86"
                       FontWeight="Bold"
                       Foreground="#EEF3FF"
                       Text="SPACE" />

            <TextBlock HorizontalAlignment="Center"
                       Margin="0,452,0,0"
                       VerticalAlignment="Top"
                       FontSize="28"
                       Foreground="#BFD0F9"
                       Text="JOIN UNIVERSE" />

            <Rectangle Height="3"
                       VerticalAlignment="Bottom"
                       Margin="180,0,180,56"
                       RadiusX="2"
                       RadiusY="2">
                <Rectangle.Fill>
                    <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,0%">
                        <GradientStop Color="#4FA6FF" Offset="0" />
                        <GradientStop Color="#BB6CFF" Offset="1" />
                    </LinearGradientBrush>
                </Rectangle.Fill>
            </Rectangle>
        </Grid>
    </Border>
</Window>
