<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:avaloniaEdit="clr-namespace:AvaloniaEdit;assembly=AvaloniaEdit"
        xmlns:mkinterp="clr-namespace:Magic.Kernel.Interpretation;assembly=Magic.Kernel"
        mc:Ignorable="d"
        x:CompileBindings="False"
        x:Class="Space.OS.Terminal2.MainWindow"
        Title="Space.OS.Terminal2"
        Height="860"
        Width="1440"
        MinHeight="700"
        MinWidth="1100"
        Background="{StaticResource BgRootBrush}"
        KeyDown="MainWindow_KeyDown">

    <Window.Resources>
        <!-- Inspect node data template for debugger tree -->
        <TreeDataTemplate x:Key="InspectNodeTemplate"
                          DataType="{x:Type mkinterp:InterpreterInspectNode}"
                          ItemsSource="{Binding Children}">
            <StackPanel Orientation="Horizontal">
                <TextBlock VerticalAlignment="Center"
                           FontWeight="SemiBold"
                           Foreground="#B8C8EC"
                           Text="{Binding Caption}" />
                <TextBlock VerticalAlignment="Center"
                           Margin="6,0,0,0"
                           MaxWidth="520"
                           Foreground="#DDE8FF"
                           Text="{Binding Detail}"
                           TextWrapping="Wrap" />
                <Button Margin="8,0,0,0"
                        Padding="8,2"
                        VerticalAlignment="Center"
                        Click="DebuggerInspectSensitiveToggle_Click"
                        Content="{Binding SensitiveRevealCaption}"
                        FontSize="10"
                        ToolTip.Tip="Показать или скрыть чувствительное значение"
                        IsVisible="{Binding IsSensitiveLeaf}" />
                <Button Margin="4,0,0,0"
                        Padding="8,2"
                        VerticalAlignment="Center"
                        Click="DebuggerInspectCopy_Click"
                        Content="Копировать"
                        FontSize="10"
                        ToolTip.Tip="Скопировать значение в буфер обмена"
                        IsVisible="{Binding ShowCopyButton}" />
                <Button Margin="4,0,0,0"
                        Padding="8,2"
                        VerticalAlignment="Center"
                        Click="DebuggerInspectViewPayload_Click"
                        Content="Просмотреть"
                        FontSize="10"
                        ToolTip.Tip="Hex-дамп (первые 48 KiB); полный файл — «Сохранить в файл»"
                        IsVisible="{Binding ShowViewPayloadButton}" />
            </StackPanel>
        </TreeDataTemplate>
    </Window.Resources>

    <Grid x:Name="RootShellGrid">
        <Grid.Background>
            <RadialGradientBrush Center="50%,30%" Radius="1.1">
                <GradientStop Color="#152553" Offset="0" />
                <GradientStop Color="#0A1332" Offset="0.45" />
                <GradientStop Color="#05081A" Offset="1" />
            </RadialGradientBrush>
        </Grid.Background>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="290" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" BorderBrush="#2B3A75" BorderThickness="0,0,1,0" Background="#0D1431">
            <DockPanel LastChildFill="True">
                <StackPanel Orientation="Horizontal" Margin="10" DockPanel.Dock="Top">
                    <Button x:Name="ToggleSidebarButton" Width="42" Height="30" Click="ToggleSidebar_Click">☰</Button>
                    <TextBlock Margin="8,5,0,0" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}">Space.OS.Terminal2</TextBlock>
                </StackPanel>
                <TreeView x:Name="NavigationTree" Margin="8" SelectionChanged="NavigationTree_SelectionChanged">
                    <TreeViewItem Header="Space" IsExpanded="True">
                        <TreeViewItem Header="Storage" Tag="space-storage" />
                        <TreeViewItem Header="Startup Exes" Tag="space-executionunits" />
                        <TreeViewItem Header="Code editor" Tag="space-code-editor" />
                        <TreeViewItem Header="Vault: Items" Tag="space-vault" />
                    </TreeViewItem>
                    <TreeViewItem Header="Monitor" IsExpanded="True">
                        <TreeViewItem Header="Exes" Tag="monitor-exes" />
                        <TreeViewItem Header="Streams" Tag="monitor-streams" />
                        <TreeViewItem Header="Drivers" Tag="monitor-drivers" />
                        <TreeViewItem Header="Connections" Tag="monitor-connections" />
                    </TreeViewItem>
                    <TreeViewItem Header="Console" IsExpanded="True">
                        <TreeViewItem Header="Logs" Tag="console-logs" />
                    </TreeViewItem>
                </TreeView>
            </DockPanel>
        </Border>

        <!-- Main content area -->
        <Grid Grid.Column="1" Margin="14">
            <Border CornerRadius="14" Background="#0D1430" BorderBrush="#2D3C79" BorderThickness="1" />
            <StackPanel Orientation="Horizontal" Margin="16,14,16,0" VerticalAlignment="Top">
                <TextBlock x:Name="SectionTitle" FontSize="24" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}">Startup Exes</TextBlock>
                <TextBlock x:Name="SectionMeta" Margin="14,7,0,0" Foreground="{StaticResource TextMutedBrush}">ready</TextBlock>
            </StackPanel>

            <Grid Margin="16,54,16,16">
                <!-- ExecutionUnits Panel -->
                <Grid x:Name="ExecutionUnitsPanel" IsVisible="True">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal">
                        <Button Click="ExecutionUnitsReload_Click">Reload</Button>
                        <Button Margin="8,0,0,0" Click="ExecutionUnitsAdd_Click">Add</Button>
                        <Button Margin="8,0,0,0" Click="ExecutionUnitsDelete_Click">Delete</Button>
                        <Button Margin="8,0,0,0" Click="ExecutionUnitsSave_Click">Save</Button>
                    </StackPanel>
                    <DataGrid x:Name="ExecutionUnitsGrid" Grid.Row="1" Margin="0,10,0,0"
                              AutoGenerateColumns="False"
                              Background="#111A3F" Foreground="#EAF1FF" BorderBrush="#3A4A8A">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Path" Binding="{Binding Path}" Width="*" />
                            <DataGridTextColumn Header="InstanceCount" Binding="{Binding InstanceCount}" Width="140" />
                            <DataGridTemplateColumn Header="" Width="72">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="Edit" FontSize="11" Padding="8,2" Click="ExecutionUnitsRowEdit_Click" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>

                <!-- Storage Panel -->
                <Grid x:Name="StoragePanel" IsVisible="False">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal">
                        <Button Click="StorageReload_Click">Reload</Button>
                        <TextBlock Margin="12,6,0,0" Foreground="{StaticResource TextMutedBrush}">All .agi files under SPACE_PATH</TextBlock>
                    </StackPanel>
                    <TreeView x:Name="StorageTree" Grid.Row="1" Margin="0,10,0,0"
                              Background="#0C1332" Foreground="#DDE8FF" BorderBrush="#3A4A8A" />
                </Grid>

                <!-- Code Editor Panel -->
                <Grid x:Name="CodeEditorPanel" IsVisible="False">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="2*" MinHeight="120" />
                        <RowDefinition Height="6" MinHeight="6" />
                        <RowDefinition Height="*" MinHeight="140" />
                    </Grid.RowDefinitions>

                    <!-- Toolbar -->
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button Classes="DebugToolbarButtonFirst"
                                    Click="CodeEditorReload_Click"
                                    ToolTip.Tip="Перечитать файл с диска">
                                <Canvas Width="15" Height="15">
                                    <Path Stroke="{Binding $parent[Button].Foreground}"
                                          StrokeThickness="1.35" StrokeLineCap="Round"
                                          Fill="Transparent"
                                          Data="M 10.8,3.2 A 5.2,5.2 0 1 0 10.8,12.8 M 10.8,3.2 L 10.8,1 M 10.8,3.2 L 13.4,4.4" />
                                </Canvas>
                            </Button>
                            <Button Classes="DebugToolbarButton"
                                    Click="CodeEditorSave_Click"
                                    ToolTip.Tip="Сохранить файл">
                                <Canvas Width="15" Height="15">
                                    <Path Stroke="{Binding $parent[Button].Foreground}"
                                          StrokeThickness="1.25" StrokeJoin="Round"
                                          Fill="Transparent"
                                          Data="M 3.5,3 H 10.5 L 12.5,5 V 13 H 3.5 Z M 3.5,9 H 12.5 M 9,3 V 6.5 H 12.5" />
                                </Canvas>
                            </Button>
                            <Button Classes="DebugToolbarButton"
                                    Click="CodeEditorDebug_Click"
                                    ToolTip.Tip="Запуск с отладкой (F5)">
                                <Canvas Width="15" Height="15">
                                    <Path Fill="{Binding $parent[Button].Foreground}"
                                          Data="M 5.5,3.5 L 5.5,12.5 L 12.5,8 Z" />
                                </Canvas>
                            </Button>
                            <TextBlock x:Name="CodeEditorRunningHint" Margin="10,0,0,0" VerticalAlignment="Center"
                                       IsVisible="False" Foreground="#7CFCA8">Running exe instance</TextBlock>
                            <Button x:Name="DebugAttachButton"
                                    Classes="DebugToolbarButton"
                                    IsVisible="False"
                                    Click="DebugAttach_Click"
                                    ToolTip.Tip="Подключиться к running exe (attach)">
                                <Canvas Width="15" Height="15">
                                    <Path Stroke="{Binding $parent[Button].Foreground}"
                                          StrokeThickness="1.35" StrokeLineCap="Round" StrokeJoin="Round"
                                          Fill="Transparent"
                                          Data="M 8,2 L 8,4.5 M 5.5,4.5 H 10.5 V 9.5 H 5.5 Z M 8,9.5 L 8,14 M 5,12 H 11" />
                                </Canvas>
                            </Button>
                            <Button x:Name="DebugRestartRunningExeButton"
                                    Classes="DebugToolbarButton"
                                    MinWidth="64"
                                    Padding="8,2"
                                    FontSize="10"
                                    IsVisible="False"
                                    Click="DebugRestartRunningExe_Click"
                                    Content="Restart"
                                    ToolTip.Tip="Сохранить .agi, остановить exe и снова запустить из executionUnits (новый код с диска); если был F5 — повторить отладку" />
                            <Button x:Name="DebugContinueButton"
                                    Classes="DebugToolbarButton"
                                    IsEnabled="False"
                                    Click="DebugContinue_Click"
                                    ToolTip.Tip="Продолжить (F9)">
                                <Canvas Width="14" Height="14">
                                    <Path Fill="{Binding $parent[Button].Foreground}"
                                          Data="M 3,2 L 13,8 3,14 Z" />
                                </Canvas>
                            </Button>
                            <Button x:Name="DebugStepButton"
                                    Classes="DebugToolbarButton"
                                    IsEnabled="False"
                                    Click="DebugStep_Click"
                                    ToolTip.Tip="Следующая строка исходника (F10)">
                                <Canvas Width="14" Height="14">
                                    <Path Stroke="{Binding $parent[Button].Foreground}"
                                          StrokeThickness="1.35" StrokeLineCap="Round"
                                          Data="M 2,5 H 14 M 8,5 V 11 M 5,8 L 8,11 L 11,8" />
                                </Canvas>
                            </Button>
                            <Button x:Name="DebugStepIntoButton"
                                    Classes="DebugToolbarButton"
                                    IsEnabled="False"
                                    Click="DebugStepInto_Click"
                                    ToolTip.Tip="Code: заход в вызов (F11). Asm/Attach: одна инструкция.">
                                <Canvas Width="14" Height="14">
                                    <Path Stroke="{Binding $parent[Button].Foreground}"
                                          StrokeThickness="1.35" StrokeLineCap="Round"
                                          Data="M 8,2 V 9 M 5,6 L 8,9 L 11,6 M 3.5,12.5 H 12.5" />
                                </Canvas>
                            </Button>
                            <Button x:Name="DebugStopButton"
                                    Classes="DebugToolbarButton"
                                    IsEnabled="False"
                                    Click="DebugStop_Click"
                                    ToolTip.Tip="Stop debugging">
                                <Canvas Width="12" Height="12">
                                    <Path Fill="{Binding $parent[Button].Foreground}"
                                          Data="M 3,3 H 13 V 13 H 3 Z" />
                                </Canvas>
                            </Button>
                            <TextBlock x:Name="CodeEditorFileText" Margin="12,0,0,0" VerticalAlignment="Center"
                                       Foreground="{StaticResource TextMutedBrush}">No file selected</TextBlock>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0,0,0">
                            <Button Classes="DebugToolbarButtonFirst"
                                    Click="CodeEditorDebugger_Click"
                                    ToolTip.Tip="Панель отладчика справа (Memory / Stack)">
                                <Canvas Width="15" Height="15">
                                    <Path Stroke="{Binding $parent[Button].Foreground}"
                                          StrokeThickness="1.25" StrokeJoin="Round"
                                          Fill="Transparent"
                                          Data="M 2.5,3.5 H 7 V 12.5 H 2.5 Z M 9,3.5 H 13.5 V 12.5 H 9 Z" />
                                </Canvas>
                            </Button>
                            <Button Classes="DebugToolbarButton"
                                    Click="CodeEditorEnvironment_Click"
                                    ToolTip.Tip="Environment: логи execution units, сеть (claw), HTTP-запросы">
                                <Canvas Width="15" Height="15">
                                    <Path Stroke="{Binding $parent[Button].Foreground}"
                                          StrokeThickness="1.25" StrokeJoin="Round"
                                          Fill="Transparent"
                                          Data="M 2.5,2.5 H 13.5 V 6.5 H 2.5 Z M 2.5,8.5 H 9.5 V 13.5 H 2.5 Z M 11,8.5 H 13.5 V 13.5 H 11 Z" />
                                </Canvas>
                            </Button>
                        </StackPanel>
                    </Grid>

                    <!-- Editor + Debugger split area -->
                    <Grid x:Name="CodeEditorMainSplitGrid"
                          Grid.Row="1"
                          Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" MinWidth="120" />
                            <ColumnDefinition Width="6" />
                            <ColumnDefinition Width="280" MinWidth="200" />
                        </Grid.ColumnDefinitions>

                        <!-- Source Tab Control (Code + Asm) -->
                        <TabControl x:Name="CodeEditorSourceTabControl"
                                    Grid.Column="0"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Padding="0"
                                    SelectionChanged="CodeEditorSourceTabs_SelectionChanged">
                            <TabItem x:Name="CodeEditorMainTab" Header="Code">
                                <avaloniaEdit:TextEditor x:Name="CodeEditor"
                                                         FontFamily="Consolas,Courier New,monospace"
                                                         FontSize="13"
                                                         ShowLineNumbers="True"
                                                         Foreground="#DDE8FF"
                                                         Background="#0C1332"
                                                         HorizontalScrollBarVisibility="Auto"
                                                         VerticalScrollBarVisibility="Auto"
                                                         WordWrap="False" />
                            </TabItem>
                            <TabItem x:Name="CodeEditorAsmTab" Header="Asm">
                                <avaloniaEdit:TextEditor x:Name="CodeAsmEditor"
                                                         FontFamily="Consolas,Courier New,monospace"
                                                         FontSize="13"
                                                         ShowLineNumbers="True"
                                                         Foreground="#C8E0D0"
                                                         Background="#0A1620"
                                                         HorizontalScrollBarVisibility="Auto"
                                                         VerticalScrollBarVisibility="Auto"
                                                         WordWrap="False" />
                            </TabItem>
                        </TabControl>

                        <!-- Debugger panel splitter -->
                        <GridSplitter x:Name="CodeEditorDebuggerColumnSplitter"
                                      Grid.Column="1"
                                      Width="6"
                                      ResizeDirection="Columns"
                                      Background="#3A4A8A"
                                      ToolTip.Tip="Ширина панели отладчика" />

                        <!-- Debugger panel -->
                        <Border x:Name="CodeEditorDebuggerPanel"
                                Grid.Column="2"
                                Margin="4,0,0,0"
                                BorderBrush="#3A4A8A"
                                BorderThickness="1,0,0,0"
                                Background="#080D22"
                                Padding="0,6,0,0">
                            <DockPanel LastChildFill="True">
                                <TextBlock x:Name="DebuggerUnitSummaryText"
                                           DockPanel.Dock="Top"
                                           Margin="8,0,8,6"
                                           Foreground="#8FA3D4"
                                           TextWrapping="Wrap"
                                           FontSize="12" />
                                <TabControl Background="Transparent" BorderThickness="0">
                                    <TabItem Header="Memory">
                                        <DockPanel LastChildFill="True">
                                            <StackPanel DockPanel.Dock="Top"
                                                        Orientation="Horizontal"
                                                        Margin="8,6,8,4">
                                                <TextBlock VerticalAlignment="Center"
                                                           Margin="0,0,10,0"
                                                           Foreground="#8FA3D4"
                                                           FontSize="11"
                                                           Text="Слой:" />
                                                <RadioButton x:Name="DebuggerMemFilterAll"
                                                             GroupName="DbgMemLayer"
                                                             Content="Все"
                                                             Margin="0,0,12,0"
                                                             Foreground="#DDE8FF"
                                                             VerticalAlignment="Center"
                                                             IsChecked="True"
                                                             IsCheckedChanged="DebuggerMemoryLayerFilter_Changed" />
                                                <RadioButton x:Name="DebuggerMemFilterGlobal"
                                                             GroupName="DbgMemLayer"
                                                             Content="Global"
                                                             Margin="0,0,12,0"
                                                             Foreground="#DDE8FF"
                                                             VerticalAlignment="Center"
                                                             IsCheckedChanged="DebuggerMemoryLayerFilter_Changed" />
                                                <RadioButton x:Name="DebuggerMemFilterLocal"
                                                             GroupName="DbgMemLayer"
                                                             Content="Local"
                                                             Margin="0,0,12,0"
                                                             Foreground="#DDE8FF"
                                                             VerticalAlignment="Center"
                                                             IsCheckedChanged="DebuggerMemoryLayerFilter_Changed" />
                                                <RadioButton x:Name="DebuggerMemFilterFrame"
                                                             GroupName="DbgMemLayer"
                                                             Content="Frame"
                                                             Foreground="#DDE8FF"
                                                             VerticalAlignment="Center"
                                                             IsCheckedChanged="DebuggerMemoryLayerFilter_Changed" />
                                            </StackPanel>
                                            <DataGrid x:Name="DebuggerMemoryGrid"
                                                      AutoGenerateColumns="False"
                                                      IsReadOnly="True"
                                                      Background="#0C1332"
                                                      Foreground="#DDE8FF"
                                                      BorderBrush="#3A4A8A"
                                                      GridLinesVisibility="Horizontal"
                                                      RowHeight="22">
                                                <DataGrid.Columns>
                                                    <DataGridTextColumn Header="Layer" Binding="{Binding Layer}" Width="90" />
                                                    <DataGridTextColumn Header="Slot" Binding="{Binding Slot}" Width="64" />
                                                    <DataGridTextColumn Header="Type" Binding="{Binding TypeName}" Width="120" />
                                                    <DataGridTextColumn Header="Value" Binding="{Binding Value}" Width="*" />
                                                </DataGrid.Columns>
                                            </DataGrid>
                                        </DockPanel>
                                    </TabItem>
                                    <TabItem Header="Stack">
                                        <DataGrid x:Name="DebuggerStackGrid"
                                                  AutoGenerateColumns="False"
                                                  IsReadOnly="True"
                                                  Background="#0C1332"
                                                  Foreground="#DDE8FF"
                                                  BorderBrush="#3A4A8A"
                                                  GridLinesVisibility="Horizontal"
                                                  RowHeight="22">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="#" Binding="{Binding Index}" Width="48" />
                                                <DataGridTextColumn Header="TOS" Binding="{Binding TopMark}" Width="52" />
                                                <DataGridTextColumn Header="Type" Binding="{Binding TypeName}" Width="120" />
                                                <DataGridTextColumn Header="Value" Binding="{Binding Value}" Width="*" />
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </TabItem>
                                </TabControl>
                            </DockPanel>
                        </Border>
                    </Grid>

                    <!-- Environment splitter -->
                    <GridSplitter x:Name="CodeEditorEnvironmentSplitter"
                                  Grid.Row="2"
                                  Height="6"
                                  ResizeDirection="Rows"
                                  Background="#3A4A8A"
                                  ToolTip.Tip="Высота панели Environment" />

                    <!-- Environment panel -->
                    <Border x:Name="CodeEditorEnvironmentPanel"
                            Grid.Row="3"
                            IsVisible="True"
                            BorderBrush="#3A4A8A"
                            BorderThickness="0,1,0,0"
                            Background="#060A18"
                            Padding="4,6,4,4"
                            MinHeight="120">
                        <TabControl Background="Transparent" BorderThickness="0">
                            <TabItem Header="Logs">
                                <TextBox x:Name="CodeEditorEnvLogsTextBox"
                                         AcceptsReturn="True"
                                         IsReadOnly="True"
                                         TextWrapping="Wrap"
                                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                                         ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                         FontFamily="Consolas,Courier New,monospace"
                                         FontSize="12"
                                         Background="#0C1332"
                                         Foreground="#C8D8F0"
                                         BorderThickness="0" />
                            </TabItem>
                            <TabItem Header="Networks">
                                <TextBox x:Name="CodeEditorEnvNetworksTextBox"
                                         AcceptsReturn="True"
                                         IsReadOnly="True"
                                         TextWrapping="Wrap"
                                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                                         ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                         FontFamily="Consolas,Courier New,monospace"
                                         FontSize="12"
                                         Background="#0C1332"
                                         Foreground="#A8E8C8"
                                         BorderThickness="0" />
                            </TabItem>
                            <TabItem Header="Requests">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="2*" MinHeight="80" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" MinHeight="60" />
                                    </Grid.RowDefinitions>
                                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,6">
                                        <Button Padding="14,4" Click="CodeEditorHttpSend_Click" Content="Send" />
                                        <Button Margin="8,0,0,0" Padding="14,4" Click="CodeEditorHttpClearResponse_Click" Content="Clear response" />
                                    </StackPanel>
                                    <avaloniaEdit:TextEditor x:Name="HttpScratchEditor"
                                                             Grid.Row="1"
                                                             FontFamily="Consolas,Courier New,monospace"
                                                             FontSize="12"
                                                             ShowLineNumbers="True"
                                                             Foreground="#DDE8FF"
                                                             Background="#0A1228"
                                                             HorizontalScrollBarVisibility="Auto"
                                                             VerticalScrollBarVisibility="Auto"
                                                             WordWrap="False" />
                                    <TextBlock Grid.Row="2"
                                               Margin="0,4,0,4"
                                               Foreground="#8FA3D4"
                                               Text="Response" />
                                    <TextBox x:Name="HttpScratchResponseTextBox"
                                             Grid.Row="3"
                                             AcceptsReturn="True"
                                             IsReadOnly="True"
                                             TextWrapping="Wrap"
                                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                                             ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                             FontFamily="Consolas,Courier New,monospace"
                                             FontSize="11"
                                             Background="#050810"
                                             Foreground="#B0C4E8"
                                             BorderThickness="0" />
                                </Grid>
                            </TabItem>
                            <TabItem Header="Console">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBox x:Name="CodeEditorEnvConsoleTextBox"
                                             Grid.Row="0"
                                             AcceptsReturn="True"
                                             IsReadOnly="True"
                                             TextWrapping="Wrap"
                                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                                             ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                             FontFamily="Consolas,Courier New,monospace"
                                             FontSize="12"
                                             Background="#050810"
                                             Foreground="#E0E8FA"
                                             BorderThickness="0" />
                                    <Grid Grid.Row="1" Margin="0,8,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="CodeEditorEnvConsoleInputTextBox"
                                                 Grid.Column="0"
                                                 MinHeight="28"
                                                 Padding="8,4"
                                                 VerticalContentAlignment="Center"
                                                 Background="#0A1228"
                                                 Foreground="#EAF1FF"
                                                 BorderBrush="#3A4A8A"
                                                 KeyDown="CodeEditorEnvConsoleInputTextBox_KeyDown" />
                                        <Button Grid.Column="1"
                                                Margin="8,0,0,0"
                                                Padding="14,4"
                                                Click="CodeEditorEnvConsoleSend_Click"
                                                Content="Send" />
                                    </Grid>
                                </Grid>
                            </TabItem>
                        </TabControl>
                    </Border>
                </Grid>

                <!-- Vault Panel -->
                <Grid x:Name="VaultPanel" IsVisible="False">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="460" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel Grid.ColumnSpan="2" Orientation="Horizontal">
                        <Button Click="VaultReload_Click">Reload</Button>
                        <Button Margin="8,0,0,0" Click="VaultAdd_Click">Add Item</Button>
                        <Button Margin="8,0,0,0" Click="VaultDelete_Click">Delete Item</Button>
                        <Button Margin="8,0,0,0" Click="VaultSave_Click">Save</Button>
                    </StackPanel>
                    <DataGrid x:Name="VaultItemsGrid" Grid.Row="1" AutoGenerateColumns="False"
                              SelectionChanged="VaultItemsGrid_SelectionChanged"
                              Background="#111A3F" Foreground="#EAF1FF" BorderBrush="#3A4A8A">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Program" Binding="{Binding Program}" Width="110" />
                            <DataGridTextColumn Header="System" Binding="{Binding System}" Width="110" />
                            <DataGridTextColumn Header="Module" Binding="{Binding Module}" Width="110" />
                            <DataGridTextColumn Header="Instance" Binding="{Binding InstanceIndex}" Width="90" />
                        </DataGrid.Columns>
                    </DataGrid>
                    <DataGrid x:Name="VaultStoreGrid" Grid.Column="1" Grid.Row="1" Margin="12,0,0,0"
                              AutoGenerateColumns="False"
                              Background="#111A3F" Foreground="#EAF1FF" BorderBrush="#3A4A8A">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Key" Binding="{Binding Key}" Width="200" />
                            <DataGridTextColumn Header="Value" Binding="{Binding Value}" Width="*" />
                            <DataGridCheckBoxColumn Header="Sensitive" Binding="{Binding IsSensitive}" Width="95" IsReadOnly="True" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>

                <!-- Monitor Panel -->
                <Grid x:Name="MonitorPanel" IsVisible="False">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal">
                        <Button Click="MonitorRefresh_Click">Refresh</Button>
                        <TextBlock x:Name="MonitorStatsText" Margin="12,6,0,0" Foreground="{StaticResource TextMutedBrush}">stats</TextBlock>
                    </StackPanel>
                    <DataGrid x:Name="MonitorGrid" Grid.Row="1" Margin="0,10,0,0" AutoGenerateColumns="False"
                              IsReadOnly="True"
                              Background="#111A3F" Foreground="#EAF1FF" BorderBrush="#3A4A8A">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="220" />
                            <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="220" />
                            <DataGridTextColumn Header="State" Binding="{Binding State}" Width="90" />
                            <DataGridTextColumn Header="Details" Binding="{Binding Details}" Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>

                <!-- Console Panel -->
                <Grid x:Name="ConsolePanel" IsVisible="False">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal">
                        <Button Click="ConsoleRefresh_Click">Refresh</Button>
                        <Button Margin="8,0,0,0" Click="ConsoleClear_Click">Clear</Button>
                        <TextBlock Margin="12,6,0,0" Foreground="{StaticResource TextMutedBrush}">Live console + interpreter print output</TextBlock>
                    </StackPanel>
                    <TextBox x:Name="ConsoleLogsTextBox" Grid.Row="1" Margin="0,10,0,0"
                             Background="#0C1332" Foreground="#DDE8FF" BorderBrush="#3A4A8A" CaretBrush="#DDE8FF"
                             FontFamily="Consolas,Courier New,monospace" FontSize="13"
                             IsReadOnly="True"
                             AcceptsReturn="True" TextWrapping="Wrap"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             ScrollViewer.HorizontalScrollBarVisibility="Auto"
                             VerticalContentAlignment="Top" Padding="8,6" />
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Window>
