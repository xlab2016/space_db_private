<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Space.OS.Terminal2.App"
             RequestedThemeVariant="Dark">

    <Application.Styles>
        <!-- Compact + explicit UI font sizes in AppStyles — WPF Terminal uses ~12px system UI; Fluent Normal looks oversized on tabs/chrome. -->
        <FluentTheme DensityStyle="Compact" />
        <StyleInclude Source="avares://Avalonia.Controls.DataGrid/Themes/Fluent.xaml" />
        <StyleInclude Source="avares://AvaloniaEdit/Themes/Fluent/AvaloniaEdit.xaml" />
        <StyleInclude Source="avares://Space.OS.Terminal2/Styles/AppStyles.axaml" />
    </Application.Styles>

    <Application.Resources>
        <Color x:Key="BgRoot">#05081A</Color>
        <Color x:Key="BgPanel">#101633</Color>
        <Color x:Key="AccentBlue">#4FA6FF</Color>
        <Color x:Key="AccentPurple">#BB6CFF</Color>
        <Color x:Key="TextPrimary">#EAF1FF</Color>
        <Color x:Key="TextMuted">#8EA3C4</Color>

        <SolidColorBrush x:Key="BgRootBrush" Color="{StaticResource BgRoot}" />
        <SolidColorBrush x:Key="BgPanelBrush" Color="{StaticResource BgPanel}" />
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimary}" />
        <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMuted}" />

        <LinearGradientBrush x:Key="AccentGradientBrush" StartPoint="0%,0%" EndPoint="100%,0%">
            <GradientStop Color="{StaticResource AccentBlue}" Offset="0" />
            <GradientStop Color="{StaticResource AccentPurple}" Offset="1" />
        </LinearGradientBrush>
    </Application.Resources>
</Application>
