<Application x:Class="Space.OS.Terminal.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Startup="Application_Startup">
    <Application.Resources>
        <Color x:Key="BgRoot">#05081A</Color>
        <Color x:Key="BgPanel">#101633</Color>
        <Color x:Key="AccentBlue">#4FA6FF</Color>
        <Color x:Key="AccentPurple">#BB6CFF</Color>
        <Color x:Key="TextPrimary">#EAF1FF</Color>
        <Color x:Key="TextMuted">#8EA3C4</Color>

        <SolidColorBrush x:Key="BgRootBrush" Color="{StaticResource BgRoot}" />
        <SolidColorBrush x:Key="BgPanelBrush" Color="{StaticResource BgPanel}" />
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimary}" />
        <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMuted}" />

        <LinearGradientBrush x:Key="AccentGradientBrush" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="{StaticResource AccentBlue}" Offset="0" />
            <GradientStop Color="{StaticResource AccentPurple}" Offset="1" />
        </LinearGradientBrush>

        <Style TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Background" Value="#1C2750" />
            <Setter Property="BorderBrush" Value="#3A4A8A" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="8"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Foreground" Value="#5C6A8A" />
                    <Setter Property="Background" Value="#13182E" />
                    <Setter Property="BorderBrush" Value="#252E50" />
                    <Setter Property="Cursor" Value="Arrow" />
                </Trigger>
                <MultiTrigger>
                    <MultiTrigger.Conditions>
                        <Condition Property="IsEnabled" Value="True" />
                        <Condition Property="IsMouseOver" Value="True" />
                    </MultiTrigger.Conditions>
                    <Setter Property="Background" Value="#273878" />
                    <Setter Property="BorderBrush" Value="#7694FF" />
                </MultiTrigger>
            </Style.Triggers>
        </Style>

        <!-- Иначе строковый ToolTip получает Foreground от TextBlock (светлый) на системном светлом фоне подсказки. -->
        <Style TargetType="ToolTip">
            <Setter Property="Background" Value="#1C2750" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="BorderBrush" Value="#3A4A8A" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,6" />
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        </Style>

        <Style TargetType="TreeView">
            <Setter Property="Background" Value="#0D1431" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="BorderBrush" Value="#2B3A75" />
        </Style>

        <Style TargetType="TreeViewItem">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Background" Value="#0D1431" />
            <Setter Property="Padding" Value="4,2" />
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="RowBackground" Value="#111A3F" />
            <Setter Property="AlternatingRowBackground" Value="#141F49" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="HeadersVisibility" Value="All" />
            <Setter Property="HorizontalGridLinesBrush" Value="#273878" />
            <Setter Property="VerticalGridLinesBrush" Value="#273878" />
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Background" Value="#1A295A" />
            <Setter Property="BorderBrush" Value="#3A4A8A" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="Padding" Value="8,6" />
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="6,4" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#2A3F84" />
                    <Setter Property="Foreground" Value="#FFFFFF" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#0E1738" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="BorderBrush" Value="#3A4A8A" />
            <Setter Property="CaretBrush" Value="#FFFFFF" />
            <Setter Property="SelectionBrush" Value="#3D57A8" />
        </Style>
    </Application.Resources>
</Application>
